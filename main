// ==UserScript==
// @name         Eruda DevTools - All Websites
// @namespace    http://yournamespace/
// @version      3.8
// @description  Inject Eruda devtools on any website
// @author       You
// @match        *://*/*
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        unsafeWindow
// @run-at       document-idle
// @require      https://cdn.jsdelivr.net/npm/eruda@3.0.1/eruda.min.js
// @require      https://cdn.jsdelivr.net/npm/eruda-dom
// @require      https://cdn.jsdelivr.net/npm/eruda-timing
// @require      https://cdn.jsdelivr.net/npm/eruda-benchmark
// @require      https://cdn.jsdelivr.net/npm/eruda-geolocation
// @require      https://cdn.jsdelivr.net/npm/eruda-features
// @require      https://cdn.jsdelivr.net/npm/eruda-orientation
// ==/UserScript==

(function() {
    'use strict';

    // Prevent double-initialization. Can't use `if (window.eruda) return` because
    // eruda is always defined in scope via @require now.
    if (document.documentElement.dataset.erudaLoaded) return;
    document.documentElement.dataset.erudaLoaded = 'true';

    const savedX = GM_getValue('erudaX', null);
    const savedY = GM_getValue('erudaY', null);

    // Use exact hostname matches to avoid partial-domain false positives
    const blacklist = [
        'accounts.google.com',
        'login.microsoftonline.com'
    ];
    if (blacklist.some(site => location.hostname === site || location.hostname.endsWith('.' + site))) return;

    eruda.init();

    // Keyboard shortcut Ctrl+Shift+E (set up immediately, not inside setTimeout)
    document.addEventListener('keydown', function(e) {
        if (e.ctrlKey && e.shiftKey && e.key === 'E') {
            eruda.show();
        }
    });

    // Double tap anywhere to open on mobile
    let lastTap = 0;
    let tapCount = 0;
    document.addEventListener('touchend', function(e) {
        const now = Date.now();
        if (now - lastTap < 300) {
            tapCount++;
            if (tapCount >= 2) {
                const entryBtn = document.querySelector('.eruda-entry-btn');
                if (entryBtn && !entryBtn.contains(e.target)) {
                    eruda.show();
                    tapCount = 0;
                }
            }
        } else {
            tapCount = 1;
        }
        lastTap = now;
    });

    setTimeout(function() {
        // Restore saved button position
        const btn = document.querySelector('.eruda-entry-btn');
        if (btn) {
            if (savedX !== null && savedY !== null) {
                try {
                    const btnW = btn.offsetWidth  || 40;
                    const btnH = btn.offsetHeight || 40;
                    // Clamp to viewport so the button can never end up off-screen
                    const clampedX = Math.max(0, Math.min(savedX, window.innerWidth  - btnW));
                    const clampedY = Math.max(0, Math.min(savedY, window.innerHeight - btnH));
                    // Unset right/bottom so left/top take full effect
                    btn.style.right  = 'auto';
                    btn.style.bottom = 'auto';
                    btn.style.left   = clampedX + 'px';
                    btn.style.top    = clampedY + 'px';
                } catch(e) {}
            }

            // Save button position when moved
            try {
                const observer = new MutationObserver(function() {
                    const rect = btn.getBoundingClientRect();
                    // Only save if the button is actually visible on screen
                    if (rect.left >= 0 && rect.top >= 0 &&
                        rect.right <= window.innerWidth && rect.bottom <= window.innerHeight) {
                        GM_setValue('erudaX', rect.left);
                        GM_setValue('erudaY', rect.top);
                    }
                });
                observer.observe(btn, { attributes: true, attributeFilter: ['style'] });
            } catch(e) {}
        }

        // Plugins are already loaded via @require — add them synchronously
        const plugins = [
            { global: 'erudaDom',         name: 'erudaDom' },
            { global: 'erudaTiming',      name: 'erudaTiming' },
            { global: 'erudaBenchmark',   name: 'erudaBenchmark' },
            { global: 'erudaGeolocation', name: 'erudaGeolocation' },
            { global: 'erudaFeatures',    name: 'erudaFeatures' },
            { global: 'erudaOrientation', name: 'erudaOrientation' }
        ];

        plugins.forEach(function(p) {
            try {
                if (window[p.global]) {
                    eruda.add(window[p.global]);
                    console.log('%c✓ Loaded: ' + p.name, 'color:cyan;');
                }
            } catch(e) {
                console.warn('%c⚠️ Could not add: ' + p.name, 'color:orange;', e);
            }
        });

        console.log('%c✅ Eruda ready with all plugins', 'color:lime; font-weight:bold;');
        addCodeTab();
        addVueTab();

    }, 500);

    // Custom JS code editor tab built from scratch
    function addCodeTab() {
        try {
            const CodeTool = {
                name: 'Code',
                init: function($el) {
                    var container = $el[0] || $el;
                    container.innerHTML = [
                        '<div style="padding:10px;height:100%;box-sizing:border-box;display:flex;flex-direction:column;">',
                        '<textarea id="eruda-code-input" style="',
                            'flex:1;',
                            'width:100%;',
                            'background:#1e1e1e;',
                            'color:#d4d4d4;',
                            'border:1px solid #444;',
                            'border-radius:6px;',
                            'padding:10px;',
                            'font-family:monospace;',
                            'font-size:13px;',
                            'resize:none;',
                            'outline:none;',
                            'box-sizing:border-box;',
                            'margin-bottom:8px;',
                        '" placeholder="// Type your JavaScript here and press Run"></textarea>',
                        '<div style="display:flex;gap:8px;margin-bottom:8px;">',
                            '<button id="eruda-code-run" style="',
                                'flex:1;',
                                'padding:8px;',
                                'background:#0e7a0d;',
                                'color:white;',
                                'border:none;',
                                'border-radius:6px;',
                                'font-size:14px;',
                                'cursor:pointer;',
                            '">&#9654; Run</button>',
                            '<button id="eruda-code-clear" style="',
                                'flex:1;',
                                'padding:8px;',
                                'background:#555;',
                                'color:white;',
                                'border:none;',
                                'border-radius:6px;',
                                'font-size:14px;',
                                'cursor:pointer;',
                            '">&#128465; Clear</button>',
                            '<button id="eruda-code-copy" style="',
                                'flex:1;',
                                'padding:8px;',
                                'background:#1a6fa8;',
                                'color:white;',
                                'border:none;',
                                'border-radius:6px;',
                                'font-size:14px;',
                                'cursor:pointer;',
                            '">&#128203; Copy</button>',
                        '</div>',
                        '<div id="eruda-code-output" style="',
                            'height:150px;',
                            'background:#111;',
                            'color:#0f0;',
                            'border:1px solid #333;',
                            'border-radius:6px;',
                            'padding:10px;',
                            'font-family:monospace;',
                            'font-size:12px;',
                            'overflow-y:auto;',
                            'white-space:pre-wrap;',
                            'word-break:break-all;',
                        '">Output will appear here...</div>',
                        '</div>'
                    ].join('');

                    const input = container.querySelector('#eruda-code-input');
                    const output = container.querySelector('#eruda-code-output');
                    const runBtn = container.querySelector('#eruda-code-run');
                    const clearBtn = container.querySelector('#eruda-code-clear');
                    const copyBtn = container.querySelector('#eruda-code-copy');

                    // Restore saved code
                    input.value = GM_getValue('erudaCode', '');

                    // Save code as you type
                    input.addEventListener('input', function() {
                        GM_setValue('erudaCode', input.value);
                    });

                    // Tab key inserts spaces instead of leaving the field
                    input.addEventListener('keydown', function(e) {
                        if (e.key === 'Tab') {
                            e.preventDefault();
                            const start = input.selectionStart;
                            const end = input.selectionEnd;
                            input.value = input.value.substring(0, start) + '    ' + input.value.substring(end);
                            input.selectionStart = input.selectionEnd = start + 4;
                        }
                        // Ctrl+Enter to run
                        if (e.ctrlKey && e.key === 'Enter') {
                            runBtn.click();
                        }
                    });

                    runBtn.addEventListener('click', function() {
                        const code = input.value;
                        if (!code.trim()) return;
                        output.style.color = '#0f0';
                        try {
                            // Use unsafeWindow so eval runs in the page's context, not the sandbox
                            const result = eval.call(unsafeWindow, code);
                            if (result !== undefined) {
                                try {
                                    output.textContent = JSON.stringify(result, null, 2);
                                } catch(e) {
                                    output.textContent = String(result);
                                }
                            } else {
                                output.textContent = 'Executed (no return value)';
                            }
                        } catch(err) {
                            output.style.color = '#ff4444';
                            output.textContent = 'Error: ' + err.message;
                        }
                    });

                    clearBtn.addEventListener('click', function() {
                        input.value = '';
                        output.style.color = '#0f0';
                        output.textContent = 'Output will appear here...';
                        GM_setValue('erudaCode', '');
                    });

                    copyBtn.addEventListener('click', function() {
                        navigator.clipboard.writeText(input.value).then(function() {
                            copyBtn.textContent = 'Copied!';
                            setTimeout(function() { copyBtn.textContent = '&#128203; Copy'; }, 1500);
                        }).catch(function() {
                            copyBtn.textContent = 'Failed';
                            setTimeout(function() { copyBtn.textContent = '&#128203; Copy'; }, 1500);
                        });
                    });
                },
                show: function() {},
                hide: function() {},
                destroy: function() {}
            };

            eruda.add(CodeTool);
            console.log('%c✓ Custom Code tab added', 'color:cyan;');
        } catch(e) {
            console.warn('Could not add Code tab:', e);
        }
    }

    // Vue component inspector tab — supports Vue 2 and Vue 3
    function addVueTab() {
        try {
            const VueTool = {
                name: 'Vue',
                init: function($el) {
                    var container = $el[0] || $el;
                    container.innerHTML = [
                        '<div style="padding:10px;height:100%;box-sizing:border-box;display:flex;flex-direction:column;">',
                        '<div style="display:flex;gap:8px;margin-bottom:8px;align-items:center;">',
                            '<span id="eruda-vue-status" style="flex:1;font-family:monospace;font-size:12px;color:#42b883;font-weight:bold;"></span>',
                            '<button id="eruda-vue-scan" style="',
                                'padding:8px 16px;',
                                'background:#42b883;',
                                'color:white;',
                                'border:none;',
                                'border-radius:6px;',
                                'font-size:14px;',
                                'cursor:pointer;',
                            '">&#8635; Scan</button>',
                        '</div>',
                        '<div id="eruda-vue-tree" style="',
                            'flex:1;',
                            'overflow-y:auto;',
                            'font-family:monospace;',
                            'font-size:12px;',
                            'background:#1a1a1a;',
                            'border:1px solid #333;',
                            'border-radius:6px;',
                            'padding:10px;',
                            'color:#ccc;',
                            'white-space:pre-wrap;',
                            'word-break:break-all;',
                        '">Press Scan to inspect Vue components.</div>',
                        '</div>'
                    ].join('');

                    const status = container.querySelector('#eruda-vue-status');
                    const tree   = container.querySelector('#eruda-vue-tree');
                    const scanBtn = container.querySelector('#eruda-vue-scan');

                    // Detect which version of Vue is on the page
                    function detectVue() {
                        // Vue 3: root element carries __vue_app__
                        const candidates = [
                            document.querySelector('[data-v-app]'),
                            document.querySelector('#app'),
                            document.body
                        ];
                        for (var i = 0; i < candidates.length; i++) {
                            var el = candidates[i];
                            if (el && el.__vue_app__) return { version: 3, app: el.__vue_app__ };
                        }
                        // Vue 2: root element carries __vue__
                        var el2 = document.querySelector('#app');
                        if (el2 && el2.__vue__) return { version: 2, root: el2.__vue__ };
                        // Vue 2 global constructor
                        if (unsafeWindow.Vue && unsafeWindow.Vue.version && unsafeWindow.Vue.version[0] === '2') {
                            return { version: 2, root: null };
                        }
                        return null;
                    }

                    // Safely stringify a value with depth limit
                    function fmt(val, depth) {
                        if (depth > 2) return '...';
                        if (val === null) return 'null';
                        if (val === undefined) return 'undefined';
                        if (typeof val !== 'object') return JSON.stringify(val);
                        if (Array.isArray(val)) {
                            if (val.length === 0) return '[]';
                            var items = val.slice(0, 5).map(function(v) { return fmt(v, depth + 1); });
                            return '[' + items.join(', ') + (val.length > 5 ? ', ...' : '') + ']';
                        }
                        var keys = Object.keys(val);
                        if (keys.length === 0) return '{}';
                        var shown = keys.slice(0, 8).map(function(k) { return k + ': ' + fmt(val[k], depth + 1); });
                        return '{ ' + shown.join(', ') + (keys.length > 8 ? ', ...' : '') + ' }';
                    }

                    // Render a Vue 2 component instance recursively
                    function renderV2(vm, indent) {
                        var name = (vm.$options && (vm.$options.name || vm.$options._componentTag)) || 'Anonymous';
                        var out = indent + '<' + name + '>\n';
                        try { if (vm.$data  && Object.keys(vm.$data).length)  out += indent + '  data:  ' + fmt(vm.$data,  0) + '\n'; } catch(e) {}
                        try { if (vm.$props && Object.keys(vm.$props).length) out += indent + '  props: ' + fmt(vm.$props, 0) + '\n'; } catch(e) {}
                        if (vm.$children && vm.$children.length) {
                            vm.$children.forEach(function(child) { out += renderV2(child, indent + '  '); });
                        }
                        return out;
                    }

                    // Walk a Vue 3 vnode tree and collect component instances
                    function collectV3Children(vnode, result) {
                        if (!vnode) return result;
                        if (vnode.component) { result.push(vnode.component); return result; }
                        if (Array.isArray(vnode.children)) {
                            vnode.children.forEach(function(c) { collectV3Children(c, result); });
                        } else if (vnode.children && typeof vnode.children === 'object') {
                            Object.values(vnode.children).forEach(function(c) {
                                if (c && typeof c === 'object') collectV3Children(c, result);
                            });
                        }
                        return result;
                    }

                    // Render a Vue 3 component instance recursively
                    function renderV3(instance, indent, depth) {
                        if (!instance || depth > 12) return '';
                        var type = instance.type || {};
                        var name = type.name || type.__name || type.displayName || 'Anonymous';
                        var out = indent + '<' + name + '>\n';
                        try { if (instance.data       && Object.keys(instance.data).length)       out += indent + '  data:  ' + fmt(instance.data,       0) + '\n'; } catch(e) {}
                        try { if (instance.props      && Object.keys(instance.props).length)      out += indent + '  props: ' + fmt(instance.props,      0) + '\n'; } catch(e) {}
                        try { if (instance.setupState && Object.keys(instance.setupState).length) out += indent + '  setup: ' + fmt(instance.setupState, 0) + '\n'; } catch(e) {}
                        if (instance.subTree) {
                            collectV3Children(instance.subTree, []).forEach(function(child) {
                                out += renderV3(child, indent + '  ', depth + 1);
                            });
                        }
                        return out;
                    }

                    function scan() {
                        tree.style.color = '#ccc';
                        tree.textContent = 'Scanning...';
                        var vue = detectVue();

                        if (!vue) {
                            status.style.color = '#ff6b6b';
                            status.textContent = 'Vue not detected';
                            tree.textContent = 'No Vue instance found on this page.\n\nThis tab works on sites that use Vue.js.';
                            return;
                        }

                        if (vue.version === 2) {
                            var ver = (unsafeWindow.Vue && unsafeWindow.Vue.version) ? unsafeWindow.Vue.version : '2.x';
                            status.style.color = '#42b883';
                            status.textContent = 'Vue ' + ver;
                            try {
                                var root = vue.root;
                                if (!root) {
                                    // Try to find it from the DOM if detectVue couldn't grab it
                                    var el = document.querySelector('#app');
                                    root = el && el.__vue__;
                                }
                                tree.textContent = root ? renderV2(root, '') : 'Vue 2 detected but root instance not accessible.';
                            } catch(e) {
                                tree.style.color = '#ff4444';
                                tree.textContent = 'Error scanning Vue 2: ' + e.message;
                            }
                        } else {
                            var appVer = vue.app.version || '3.x';
                            status.style.color = '#42b883';
                            status.textContent = 'Vue ' + appVer;
                            try {
                                var rootInstance = vue.app._instance;
                                tree.textContent = rootInstance ? renderV3(rootInstance, '', 0) : 'Vue 3 detected but root instance not accessible.';
                            } catch(e) {
                                tree.style.color = '#ff4444';
                                tree.textContent = 'Error scanning Vue 3: ' + e.message;
                            }
                        }
                    }

                    scanBtn.addEventListener('click', scan);
                    scan(); // auto-scan when tab opens
                },
                show: function() {},
                hide: function() {},
                destroy: function() {}
            };

            eruda.add(VueTool);
            console.log('%c✓ Vue tab added', 'color:cyan;');
        } catch(e) {
            console.warn('Could not add Vue tab:', e);
        }
    }

})();
